---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingForm from '../components/BookingForm.astro';
import heroImg from '../assets/photo-4.jpg';
import { siteConfig } from '../data/site';

const title = 'Wedding Magician Vancouver & Surrey | Close-Up Magic by Geo';
const description =
  'Wedding and private party close-up magic in Vancouver, Surrey, and the Lower Mainland: interactive magic that brings guests together from cocktails through the reception.';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weddings', url: '/weddings/' },
];

const serviceJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Wedding close-up magic',
  description,
  provider: { '@id': `${siteConfig.siteUrl}/#business` },
  areaServed: siteConfig.areaServed.map((name) => ({ '@type': 'City', name })),
  serviceType: 'Wedding entertainment',
};
---

<BaseLayout title={title} description={description} pathname="/weddings/" theme="default" breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJson)} />
  <div class="relative">
    <div class="aspect-[16/7] w-full overflow-hidden md:aspect-[16/6]">
      <Picture
        src={heroImg}
        alt="Geo performs close-up magic at a reception table as a guest holds her selected card in surprise"
        formats={['avif', 'webp']}
        widths={[640, 1024, 1280, 1600, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent"></div>
    </div>
  </div>
  <article class="mx-auto max-w-3xl px-4 py-16 md:py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-300/90">Weddings & receptions</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white md:text-5xl">Wedding magician for Vancouver, Surrey & the Lower Mainland</h1>
    <p class="mt-6 text-lg leading-relaxed text-white/75">
      Make your special day unforgettable with magic that brings guests together. From close-up card tricks to mind-reading moments, I create{' '}
      <strong class="text-white">interactive experiences</strong> that leave your guests amazed. Whether during cocktails or throughout your
      reception, I help keep everyone engaged and talking about your event long after it is over.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Why close-up magic works at weddings</h2>
    <p class="mt-4 leading-relaxed text-white/75">
      Close-up, strolling magic is the perfect icebreaker while photos run or tables settle. I move from group to group with refined, conversational
      material, never interrupting speeches or pulling focus from you, just elevating the room while people mingle across Vancouver, Surrey, and the
      Fraser Valley.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Wedding magic across Vancouver, Surrey, and beyond</h2>
    <p class="mt-4 leading-relaxed text-white/75">
      Based in <strong class="text-white">Surrey, BC</strong>, I serve <strong class="text-white">Greater Vancouver</strong> including Vancouver
      proper, Burnaby, Richmond, North & West Vancouver, New Westminster, Tri-Cities, Langley, and White Rock. Planning a destination-style weekend in
      the Fraser Valley? Include your venue in the inquiry and I will confirm logistics.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">What you can expect</h2>
    <ul class="mt-4 list-disc space-y-2 pl-5 text-white/75">
      <li>Magic with cards, coins, and borrowed objects, intimate and elegant.</li>
      <li>Dress code matched to your celebration (black-tie adjacent when needed).</li>
      <li>Timing aligned with your planner: cocktails, patio mingling, or a reception “golden hour.”</li>
    </ul>
    <p class="mt-10 leading-relaxed text-white/75">
      Let&apos;s make your celebration truly magical!{' '}
      <a href="/#book" class="font-semibold text-amber-300 underline-offset-4 hover:underline">Check Availability</a>
      {' '}for your wedding in Vancouver or Surrey, and I will reply with availability and next steps.
    </p>
  </article>
  <BookingForm theme="default" />
</BaseLayout>
