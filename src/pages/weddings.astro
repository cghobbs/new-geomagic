---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingForm from '../components/BookingForm.astro';
import heroImg from '../assets/photo-4.jpg';
import { siteConfig } from '../data/site';

const title = 'Wedding Magician Vancouver & Surrey | Close-Up Magic by Geo';
const description =
  'Wedding close-up magic for Vancouver and Surrey: interactive magic from cocktail hour through the reception, tailored to your celebration.';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weddings', url: '/weddings/' },
];

const serviceJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Wedding close-up magic',
  description,
  provider: { '@id': `${siteConfig.siteUrl}/#business` },
  areaServed: siteConfig.areaServed.map((name) => ({ '@type': 'City', name })),
  serviceType: 'Wedding entertainment',
  dateModified: new Date().toISOString(),
};

const packages = [
  {
    icon: '🥂',
    name: 'Strolling Magic',
    tagline: 'The perfect icebreaker',
    body: 'During cocktail hour, patio mingling, or a reception "golden hour," I move from group to group creating intimate moments of wonder for your guests. It is unhurried, conversational, and tailored to the room. Your guests will not just watch the magic happen — they will be part of it.',
    idealFor: 'Cocktail receptions, mingling periods, and any window where guests are on their feet and mixing.',
    featured: false,
  },
  {
    icon: '✨',
    name: 'Show + Strolling',
    tagline: 'A complete entertainment experience',
    body: 'This package combines a 30-minute stage show with a strolling close-up set, giving your guests two distinct experiences in one evening. The stage show gathers your guests together for a shared moment of spectacle — mind-reading, impossible predictions, and jaw-dropping moments for the whole room. Then I work the room one-on-one, creating up-close personal wonder for each group.',
    idealFor: 'Receptions where you want a defined entertainment highlight alongside ongoing mingling magic.',
    featured: false,
  },
  {
    icon: '💍',
    name: 'The Full Celebration',
    tagline: 'Magic + MC',
    body: 'For couples who want a seamlessly hosted evening from start to finish, this package adds professional wedding MC services to the full show and strolling experience. I will keep the energy moving, introduce key moments (first dance, speeches, toasts, cake cutting), and handle the room logistics — so you never have to think about it.',
    idealFor: 'Receptions where you want one trusted entertainer to hold the whole evening together.',
    featured: true,
  },
];

const expectItems = [
  'Dress code matched to your celebration (black-tie adjacent when needed).',
  'A pre-event conversation to align on timing, tone, and any moments that matter most.',
  'Coordination with your venue coordinator or wedding planner.',
  'A performance style that is warm, inclusive, and never crude or off-colour.',
];

const areas = [
  'Vancouver', 'Burnaby', 'Richmond', 'North Vancouver',
  'West Vancouver', 'New Westminster', 'Tri-Cities', 'Langley', 'White Rock', 'Surrey',
];
---

<BaseLayout title={title} description={description} pathname="/weddings/" theme="default" breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJson)} />

  <!-- Hero -->
  <div class="relative">
    <div class="aspect-[16/7] w-full overflow-hidden md:aspect-[16/6]">
      <Picture
        src={heroImg}
        alt="Geo performs close-up magic at a reception table as a guest holds her selected card in surprise"
        formats={['avif', 'webp']}
        widths={[640, 1024, 1280, 1600, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent"></div>
    </div>
  </div>

  <!-- Intro -->
  <div class="mx-auto max-w-3xl px-4 pt-16 md:pt-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-300/90">Weddings & receptions</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white md:text-5xl">
      Wedding magician for Vancouver, Surrey & the Lower Mainland
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-white/75">
      Make your special day unforgettable with magic that brings guests together. From intimate moments of wonder during cocktail hour to a headline show your guests will be talking about for years, I offer wedding entertainment packages built around your celebration. Whether you want strolling close-up magic, a stage show, or the full experience with a wedding MC, I will work with you to make it feel effortless.
    </p>
  </div>

  <!-- Why magic works -->
  <div class="mx-auto max-w-3xl px-4 py-14">
    <h2 class="text-2xl font-semibold text-white">Why magic works at weddings</h2>
    <div class="mt-6 space-y-4 leading-relaxed text-white/75">
      <p>
        A wedding brings together people from every corner of your life. Magic is the great connector. It breaks the ice, draws people into conversation, and creates shared moments of genuine astonishment that guests carry with them long after the night ends.
      </p>
      <p>
        I move through your event with a warm, conversational style, never competing with speeches or pulling focus from you and your partner. The magic happens right in front of your guests — sometimes right in their hands — which makes it feel personal in a way that no stage show alone ever could.
      </p>
      <p>
        Close-up magic has been performed at celebrations for centuries. Organizations like the{' '}
        <a href="https://www.ibmagi.com/" target="_blank" rel="noopener" class="font-medium text-amber-300 underline-offset-4 hover:underline">International Brotherhood of Magicians</a>{' '}
        — the world's oldest and largest magic organization — uphold the professional standards that make live close-up magic a trusted choice for milestone events. Vancouver's own{' '}
        <a href="https://www.hiddenwonders.ca/" target="_blank" rel="noopener" class="font-medium text-amber-300 underline-offset-4 hover:underline">Hidden Wonders</a>{' '}
        has helped put the city on the map as a destination for world-class close-up performance.
      </p>
    </div>
  </div>

  <!-- Packages -->
  <div class="mx-auto max-w-5xl px-4 pb-14">
    <h2 class="text-2xl font-semibold text-white md:text-3xl">Wedding packages</h2>
    <div class="mt-8 grid gap-5 lg:grid-cols-3">
      {packages.map((pkg) => (
        <div
          class:list={[
            'flex flex-col rounded-2xl border p-6 transition',
            pkg.featured
              ? 'border-amber-400/40 bg-amber-400/[0.04]'
              : 'border-white/10 bg-white/[0.03]',
          ]}
        >
          <span class="text-3xl" aria-hidden="true">{pkg.icon}</span>
          <h3 class="mt-4 text-xl font-semibold text-white">{pkg.name}</h3>
          <p class="mt-1 text-sm font-medium text-amber-300/70">{pkg.tagline}</p>
          <p class="mt-4 flex-1 text-sm leading-relaxed text-white/70">{pkg.body}</p>
          <div class:list={[
            'mt-6 rounded-xl p-3',
            pkg.featured ? 'bg-amber-400/[0.07]' : 'bg-white/[0.04]',
          ]}>
            <p class="text-xs font-semibold uppercase tracking-wider text-white/40">Ideal for</p>
            <p class="mt-1 text-sm leading-relaxed text-white/60">{pkg.idealFor}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- What to expect -->
  <div class="mx-auto max-w-3xl px-4 pb-14">
    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
      <h2 class="text-xl font-semibold text-white">What you can expect from every package</h2>
      <ul class="mt-5 space-y-3">
        {expectItems.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0 text-amber-300" aria-hidden="true">✓</span>
            <span class="text-sm leading-relaxed text-white/70">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Service area -->
  <div class="mx-auto max-w-3xl px-4 pb-14">
    <h2 class="text-2xl font-semibold text-white">Wedding magic across Vancouver, Surrey & beyond</h2>
    <p class="mt-4 leading-relaxed text-white/70">
      Based in <strong class="text-white">Surrey, BC</strong>, I serve Greater Vancouver and surrounding areas. Planning a wedding in the Fraser Valley or beyond? Include your venue in the inquiry and I will confirm logistics.
    </p>
    <div class="mt-5 flex flex-wrap gap-2">
      {areas.map((city) => (
        <span class="rounded-full border border-white/15 bg-white/[0.04] px-3 py-1 text-sm text-white/60">
          {city}
        </span>
      ))}
    </div>
  </div>

  <!-- Testimonials -->
  <div class="mx-auto max-w-3xl px-4 pb-14">
    <h2 class="text-2xl font-semibold text-white">What guests say</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <blockquote class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
        <p class="text-2xl leading-none text-amber-300/30 font-serif" aria-hidden="true">"</p>
        <p class="mt-2 text-sm leading-relaxed text-white/75 italic">
          It really added an extra level of flair and class to the event.
        </p>
        <footer class="mt-4 text-xs text-white/40">— Guest at a recent event</footer>
      </blockquote>
      <blockquote class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
        <p class="text-2xl leading-none text-amber-300/30 font-serif" aria-hidden="true">"</p>
        <p class="mt-2 text-sm leading-relaxed text-white/75 italic">
          He's such a classy magician, no crude or strange jokes, just quality magic and fun!
        </p>
        <footer class="mt-4 text-xs text-white/40">— Guest at a recent event</footer>
      </blockquote>
    </div>
  </div>

  <!-- CTA -->
  <div class="mx-auto max-w-3xl px-4 pb-20">
    <div class="rounded-2xl border border-amber-400/20 bg-amber-400/[0.04] p-8 text-center">
      <h2 class="text-2xl font-semibold text-white">Ready to make it magical?</h2>
      <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-white/70">
        Every wedding is different, and every package can be tailored to your timeline and vision. Reach out with your date, venue, and a sense of what you are looking for, and I will come back to you with availability and a recommendation for which package fits best.
      </p>
      <a
        href="#book"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-amber-400 px-8 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-amber-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-300"
      >
        Check Availability
      </a>
    </div>
  </div>

  <BookingForm theme="default" />
</BaseLayout>
