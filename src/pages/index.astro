---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HomeSections from '../components/HomeSections.astro';
import { homeFaqPreview } from '../data/faq';

const title = 'Close-Up Magician Vancouver | Wedding & Corporate Magic by Geo';
const description =
  'Hire a Vancouver close-up magician for weddings, corporate events, and private parties. Strolling magic across Greater Vancouver, Surrey, and the Lower Mainland.';
const faqForSchema = homeFaqPreview.map((f) => ({ question: f.question, answer: f.answer }));
---

<BaseLayout title={title} description={description} pathname="/" theme="cinematic" faqItems={faqForSchema}>
  <Hero />
  <HomeSections theme="cinematic" />
  <div class="mx-auto max-w-3xl px-4 pb-10 text-center">
    <p class="text-sm leading-relaxed text-white/40">
      Geo performs in the tradition of close-up artists celebrated by organizations like the{' '}
      <a href="https://www.ibmagi.com/" target="_blank" rel="noopener" class="text-amber-300/60 underline-offset-4 hover:underline">International Brotherhood of Magicians</a>.
      He was inspired to start performing after discovering the Vancouver close-up scene through{' '}
      <a href="https://www.hiddenwonders.ca/" target="_blank" rel="noopener" class="text-amber-300/60 underline-offset-4 hover:underline">Hidden Wonders</a>,
      Shawn Farquhar's acclaimed speakeasy magic show in New Westminster.
    </p>
  </div>
</BaseLayout>
