---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HomeSections from '../components/HomeSections.astro';

const title = 'Geo | Close-Up Magician for Vancouver, Surrey & the Lower Mainland';
const description =
  'Hire Geo for elegant close-up magic at weddings, corporate events, and private parties across Greater Vancouver — Surrey, Vancouver, Burnaby, Richmond & beyond.';
---

<BaseLayout title={title} description={description} pathname="/" theme="cinematic">
  <Hero />
  <HomeSections theme="cinematic" />
</BaseLayout>
