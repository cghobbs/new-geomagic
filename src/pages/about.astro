---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingForm from '../components/BookingForm.astro';

const title = 'About Geo | Close-Up Magician | Surrey & Vancouver';
const description =
  'Hello, I\'m Geo, a close-up magician based in Surrey, BC. Elevate your events with mind-bending illusions and unforgettable moments of wonder across Greater Vancouver.';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about/' },
];
---

<BaseLayout title={title} description={description} pathname="/about/" theme="default" breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-3xl px-4 py-16 md:py-20">
    <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">About Geo</h1>
    <p class="mt-6 text-lg leading-relaxed text-white/75">
      Hello, I&apos;m <strong class="text-white">Geo</strong> and I&apos;m a close-up magician based in <strong class="text-white">Surrey, BC</strong>, serving{' '}
      <strong class="text-white">Greater Vancouver</strong>. I elevate events with mind-bending illusions and unforgettable moments of wonder, perfect
      for corporate events, private parties, and special celebrations.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Close-up magic that creates genuine reactions</h2>
    <p class="mt-4 leading-relaxed text-white/75">
      Close-up, strolling magic is an interactive experience where the magic happens right in the hands of your guests. As I move from group to
      group, I perform mind-blowing illusions with cards, coins, and everyday objects, creating personal moments of astonishment. It&apos;s the perfect
      way to break the ice, spark conversations, and leave a lasting impression at any event.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Who I perform for</h2>
    <p class="mt-4 leading-relaxed text-white/75">
      <strong class="text-white">Weddings and private parties</strong> where you want guests brought together with interactive magic they remember.{' '}
      <strong class="text-white">Corporate events</strong> where you want conversation and connection, tailored to your brand.{' '}
      <strong class="text-white">Fundraising galas</strong> where magic can highlight your cause and keep guests engaged. If you value details and a
      polished guest experience, we will likely be a strong fit.
    </p>
    <p class="mt-10">
      Want to see if we&apos;re a fit?{' '}
      <a href="/#book" class="font-semibold text-amber-300 underline-offset-4 hover:underline">Check Availability</a>.
    </p>
  </article>
  <BookingForm theme="default" />
</BaseLayout>
