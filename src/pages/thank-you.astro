---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank you | Magic by Geo"
  description="Your inquiry was received. Geo will reply shortly."
  pathname="/thank-you/"
  theme="cinematic"
  robots="noindex,follow"
  minimal
>
  <section class="mx-auto max-w-xl px-4 py-24 text-center">
    <h1 class="text-3xl font-semibold text-white">Thank you</h1>
    <p class="mt-4 text-white/75">
      Your message is on its way. I’ll reply as soon as I can, usually within one business day, with availability and next steps.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex min-h-12 items-center justify-center rounded-full bg-amber-400 px-6 text-sm font-semibold text-zinc-950 hover:bg-amber-300"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
