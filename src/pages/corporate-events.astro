---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingForm from '../components/BookingForm.astro';
import heroImg from '../assets/photo-2.jpg';
import { siteConfig } from '../data/site';

const title = 'Corporate Magician Vancouver & Surrey | Magic by Geo';
const description =
  'Corporate close-up magician for Vancouver and Surrey: tailored magic for galas, awards, team events, and receptions across the Lower Mainland.';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Corporate events', url: '/corporate-events/' },
];

const serviceJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Corporate close-up magic',
  description,
  provider: { '@id': `${siteConfig.siteUrl}/#business` },
  areaServed: siteConfig.areaServed.map((name) => ({ '@type': 'City', name })),
  serviceType: 'Corporate entertainment',
};
---

<BaseLayout
  title={title}
  description={description}
  pathname="/corporate-events/"
  theme="default"
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJson)} />
  <div class="relative">
    <div class="aspect-[16/7] w-full overflow-hidden md:aspect-[16/6]">
      <Picture
        src={heroImg}
        alt="Geo performing close-up magic at a corporate luncheon for a small group of professionals"
        formats={['avif', 'webp']}
        widths={[640, 1024, 1280, 1600, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent"></div>
    </div>
  </div>
  <article class="mx-auto max-w-3xl px-4 py-16 md:py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-300/90">Corporate & brand events</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white md:text-5xl">Corporate magician for Vancouver & Surrey events</h1>
    <p class="mt-6 text-lg leading-relaxed text-white/75">
      Elevate your corporate event with magic that sparks conversation and connection. Whether it is a team-building workshop or an awards ceremony,
      I tailor my performance to fit your event and brand. From intimate close-up magic to high-energy routines, I create a memorable experience that
      leaves a lasting impact across Vancouver, Surrey, and the Lower Mainland.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Built for professional rooms</h2>
    <p class="mt-4 leading-relaxed text-white/75">
      Material is clean, contemporary, and audience-aware, designed for mixed groups, executives, and guests who may not know each other yet. The
      goal is simple: make your brand moment feel effortless and elevated.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Corporate events across the Lower Mainland</h2>
    <p class="mt-4 leading-relaxed text-white/75">
      From downtown Vancouver hotels to Surrey convention-adjacent venues, Burnaby studios, Richmond conference centres, and North Shore retreats, I
      travel throughout <strong class="text-white">Greater Vancouver</strong> with a self-contained, low-footprint performance style (no stage
      required for close-up).
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Fundraising galas</h2>
    <p class="mt-4 leading-relaxed text-white/75">
      Transform your fundraising gala into a magical experience that encourages generosity. Through mind-blowing magic and interactive moments, I
      engage guests while highlighting your cause. Whether during cocktails, dinner, or the live auction, I integrate magic that keeps your guests
      connected and excited to give.
    </p>
    <p class="mt-4 leading-relaxed text-white/75">
      Let&apos;s craft an experience that exceeds your goals. Share your program, audience, and fundraising moments in the inquiry, and we will map
      the right performance windows.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-white">Common corporate bookings</h2>
    <ul class="mt-4 list-disc space-y-2 pl-5 text-white/75">
      <li>Holiday parties & year-end celebrations</li>
      <li>Client appreciation & VIP receptions</li>
      <li>Conference cocktail blocks & sponsor lounges</li>
      <li>Gala dinners (cocktail and pre-program mingling)</li>
    </ul>
    <p class="mt-10 leading-relaxed text-white/75">
      Let&apos;s make your next corporate event stand out!{' '}
      <a href="/#book" class="font-semibold text-amber-300 underline-offset-4 hover:underline">Check Availability</a>
      {' '}and include your run-of-show, guest count, and dress code.
    </p>
  </article>
  <BookingForm theme="default" />
</BaseLayout>
