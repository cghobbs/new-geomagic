---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingForm from '../components/BookingForm.astro';
import heroImg from '../assets/photo-6.jpg';
import { siteConfig } from '../data/site';

const title = 'Private Party Magician Vancouver & Surrey | Magic by Geo';
const description =
  'Private party close-up magician for birthdays, anniversaries, and special celebrations in Vancouver, Surrey, Burnaby, Richmond, and Greater Vancouver.';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Private parties', url: '/private-parties/' },
];

const serviceJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Private party close-up magic',
  description,
  provider: { '@id': `${siteConfig.siteUrl}/#business` },
  areaServed: siteConfig.areaServed.map((name) => ({ '@type': 'City', name })),
  serviceType: 'Private event entertainment',
  dateModified: new Date().toISOString(),
};

const packages = [
  {
    icon: '🎩',
    name: 'Strolling Magic',
    tagline: 'The go-to for most private parties',
    body: 'I move through the room in clusters, spending a few minutes with each group and leaving them with a shared moment they will be talking about for the rest of the night. No staging, no setup, no microphone — just magic that happens right in the middle of your party. It is unhurried, conversational, and shaped by the room.',
    idealFor: 'Parties of any size, cocktail hours, backyard gatherings, private dining rooms, and home celebrations.',
  },
  {
    icon: '✨',
    name: 'Show + Strolling',
    tagline: 'For milestone occasions that deserve a moment',
    body: 'This package adds a 20 to 30-minute stand-up show to the strolling experience. The show gathers your guests for a shared highlight — mind-reading, impossible predictions, full-room participation — then the strolling magic brings it back down to an intimate, personal level for the rest of the evening.',
    idealFor: 'Milestone birthdays, anniversary parties, retirement celebrations, and any occasion where you want a proper entertainment centrepiece.',
  },
];

const occasions = [
  'Milestone birthdays (40th, 50th, 60th, 70th+)',
  'Anniversary parties',
  'Retirement celebrations',
  'Engagement parties',
  'Graduation parties',
  'Holiday gatherings',
  'Housewarming parties',
  'Family reunions',
];

const expectItems = [
  'Magic tailored to your guest list — age range, vibe, and how formal the evening is.',
  'A conversation before the event so I understand what matters and what to avoid.',
  'Self-contained performance style — no staging, PA system, or special setup required for strolling.',
  'Flexible timing around food, speeches, and any program moments you have planned.',
  'A polished, low-maintenance experience so you can actually enjoy your own party.',
];

const areas = [
  'Vancouver', 'Burnaby', 'Richmond', 'North Vancouver',
  'West Vancouver', 'New Westminster', 'Tri-Cities', 'Langley', 'White Rock', 'Surrey',
];

const testimonials = [
  {
    quote: 'It really added an extra level of flair and class to the event.',
    attribution: 'Guest at a recent event',
  },
  {
    quote: "He's such a classy magician, no crude or strange jokes, just quality magic and fun!",
    attribution: 'Guest at a recent event',
  },
];
---

<BaseLayout title={title} description={description} pathname="/private-parties/" theme="default" breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJson)} />

  <!-- Hero -->
  <div class="relative">
    <div class="aspect-[16/7] w-full overflow-hidden md:aspect-[16/6]">
      <Picture
        src={heroImg}
        alt="Geo reveals a chosen card and the spectators gasp in disbelief at a private celebration"
        formats={['avif', 'webp']}
        widths={[640, 1024, 1280, 1600, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent"></div>
    </div>
  </div>

  <!-- Intro -->
  <div class="mx-auto max-w-3xl px-4 pt-16 md:pt-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-300/90">Private celebrations</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white md:text-5xl">
      Private party magician, Vancouver to Surrey
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-white/75">
      Make your celebration unforgettable with magic that brings guests together. Whether you are hosting a milestone birthday, an anniversary, or a gathering of people who do not all know each other yet, close-up magic is one of the most natural ways to make a room feel alive. And the best part: once the magic is running, you get to be a guest at your own party.
    </p>
  </div>

  <!-- Why it works -->
  <div class="mx-auto max-w-3xl px-4 py-14">
    <h2 class="text-2xl font-semibold text-white">Why magic works at private parties</h2>
    <div class="mt-5 space-y-4 leading-relaxed text-white/75">
      <p>
        Most private parties bring together people from different parts of your life — friends, family, colleagues, partners of friends — who may not know each other at all. Magic is a natural connector. It gives strangers an immediate shared experience, sparks conversation, and creates the kind of warmth that takes a good party and makes it a great one.
      </p>
      <p>
        It also works across ages. The same moment that floors a 60-year-old works on a 12-year-old, and that versatility matters when your guest list spans generations. The material is always clean, always warm, and always calibrated to the room.
      </p>
      <p>
        I was first drawn into close-up magic after seeing it performed live at{' '}
        <a href="https://www.hiddenwonders.ca/" target="_blank" rel="noopener" class="font-medium text-amber-300 underline-offset-4 hover:underline">Hidden Wonders</a>,{' '}
        Shawn Farquhar's speakeasy magic show in New Westminster. That evening reminded me why live, intimate performance creates something no other entertainment can: genuine, unfiltered human surprise. It is also why organizations like the{' '}
        <a href="https://www.ibmagi.com/" target="_blank" rel="noopener" class="font-medium text-amber-300 underline-offset-4 hover:underline">International Brotherhood of Magicians</a>{' '}
        — the world's largest professional magic association — have celebrated the art form for over a century.
      </p>
    </div>
  </div>

  <!-- Packages -->
  <div class="mx-auto max-w-4xl px-4 pb-14">
    <h2 class="text-2xl font-semibold text-white md:text-3xl">Packages</h2>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {packages.map((pkg) => (
        <div class="flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <span class="text-3xl" aria-hidden="true">{pkg.icon}</span>
          <h3 class="mt-4 text-xl font-semibold text-white">{pkg.name}</h3>
          <p class="mt-1 text-sm font-medium text-amber-300/70">{pkg.tagline}</p>
          <p class="mt-4 flex-1 text-sm leading-relaxed text-white/70">{pkg.body}</p>
          <div class="mt-6 rounded-xl bg-white/[0.04] p-3">
            <p class="text-xs font-semibold uppercase tracking-wider text-white/40">Ideal for</p>
            <p class="mt-1 text-sm leading-relaxed text-white/60">{pkg.idealFor}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Occasions -->
  <div class="mx-auto max-w-4xl px-4 pb-14">
    <h2 class="text-2xl font-semibold text-white">Great for any occasion</h2>
    <div class="mt-5 flex flex-wrap gap-2">
      {occasions.map((occasion) => (
        <span class="rounded-full border border-white/15 bg-white/[0.04] px-3 py-1.5 text-sm text-white/60">
          {occasion}
        </span>
      ))}
    </div>
  </div>

  <!-- What you can expect -->
  <div class="mx-auto max-w-4xl px-4 pb-14">
    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
      <h2 class="text-xl font-semibold text-white">What you can expect</h2>
      <ul class="mt-5 space-y-3">
        {expectItems.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0 text-amber-300" aria-hidden="true">✓</span>
            <span class="text-sm leading-relaxed text-white/70">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Service area -->
  <div class="mx-auto max-w-4xl px-4 pb-14">
    <h2 class="text-2xl font-semibold text-white">Serving Greater Vancouver</h2>
    <p class="mt-4 leading-relaxed text-white/70">
      Based in <strong class="text-white">Surrey, BC</strong>, I am a short drive from across the Lower Mainland. Whether your party is in a Vancouver penthouse, a Burnaby private room, a Richmond restaurant, or a backyard in Langley — include your neighbourhood in the inquiry and I will confirm the details.
    </p>
    <div class="mt-5 flex flex-wrap gap-2">
      {areas.map((city) => (
        <span class="rounded-full border border-white/15 bg-white/[0.04] px-3 py-1 text-sm text-white/60">
          {city}
        </span>
      ))}
    </div>
  </div>

  <!-- Testimonials -->
  <div class="mx-auto max-w-4xl px-4 pb-14">
    <h2 class="text-2xl font-semibold text-white">What guests say</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {testimonials.map((t) => (
        <blockquote class="flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <p class="text-2xl leading-none text-amber-300/30 font-serif" aria-hidden="true">"</p>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-white/75 italic">{t.quote}</p>
          <footer class="mt-4 text-xs text-white/40">— {t.attribution}</footer>
        </blockquote>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <div class="mx-auto max-w-4xl px-4 pb-20">
    <div class="rounded-2xl border border-amber-400/20 bg-amber-400/[0.04] p-8 text-center">
      <h2 class="text-2xl font-semibold text-white">Ready to make it a night to remember?</h2>
      <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-white/70">
        Share your date, venue, guest count, and the occasion you are celebrating, and I will come back to you with availability and a recommendation for which package fits best.
      </p>
      <a
        href="#book"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-amber-400 px-8 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-amber-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-300"
      >
        Check Availability
      </a>
    </div>
  </div>

  <BookingForm theme="default" />
</BaseLayout>
