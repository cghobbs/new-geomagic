---
interface Props {
  theme?: 'velvet' | 'noir' | 'cinematic' | 'default';
}

const { theme = 'default' } = Astro.props;

const headingFont =
  theme === 'velvet'
    ? 'font-[family-name:var(--font-display-velvet)] text-[var(--color-velvet-gold)]'
    : theme === 'noir'
      ? 'font-[family-name:var(--font-display-noir)]'
      : theme === 'cinematic'
        ? 'font-[family-name:var(--font-display-cinematic)]'
        : 'font-[family-name:var(--font-display-noir)]';

const steps = [
  {
    n: "01",
    title: "Tell me about your event",
    body: "Use the contact form below to share the details that matter most: the occasion, venue and city, guest count, the goal of the event, and the atmosphere you're going for. The more context you give me, the better I can tailor the experience.",
  },
  {
    n: "02",
    title: "We plan it together",
    body: "I'll work with you to make sure the magic fits your event — not just the timing and format, but the tone, the audience, and the moments you want to create. Every performance is built around your event, not a generic set.",
  },
  {
    n: "03",
    title: "Sit back and enjoy the night",
    body: "I arrive prepared, dressed to your code, and ready to perform. You focus on hosting — I'll handle making your guests feel like the night was made for them.",
  },
];
---

<section class="border-y border-white/10 bg-black/25 py-16 md:py-24" aria-labelledby="process-heading">
  <div class="mx-auto max-w-6xl px-4">
    <h2 id="process-heading" class:list={['text-center text-3xl md:text-4xl text-white', headingFont]}>
      How booking works
    </h2>
    <ol class="mt-12 grid gap-8 md:grid-cols-3">
      {
        steps.map((s) => (
          <li class="relative rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <span class="text-xs font-bold uppercase tracking-[0.2em] text-amber-300/80">{s.n}</span>
            <h3 class="mt-2 text-lg font-semibold text-white">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/70">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
