---
/** Cinematic, full-bleed hero with editorial overlay */
---

<section class="relative min-h-[78vh] border-b border-white/10 md:min-h-[85vh]">
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src="/images/photo-8.png"
      alt=""
      role="presentation"
      class="h-full w-full object-cover"
      width={1280}
      height={899}
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/70 to-black/30 md:bg-gradient-to-r md:from-black md:via-black/55 md:to-transparent"></div>
  </div>
  <div class="relative flex min-h-[78vh] flex-col justify-end px-4 pb-16 pt-32 md:min-h-[85vh] md:justify-center md:pb-0 md:pt-0">
    <div class="mx-auto w-full max-w-6xl md:pb-20">
      <p class="text-[10px] font-semibold uppercase tracking-[0.5em] text-white/70 md:text-xs">Greater Vancouver · Close-Up Magic</p>
      <h1 class="mt-4 max-w-[14ch] font-[family-name:var(--font-display-cinematic)] text-[clamp(2.75rem,8vw,5rem)] font-semibold leading-[0.95] text-white">
        Geo
      </h1>
      <p class="mt-2 max-w-lg text-lg font-light leading-snug text-white/90 md:text-xl">
        Close-up magic for weddings, corporate events, and private parties from Surrey to Vancouver.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#book"
          class="inline-flex min-h-12 min-w-[11rem] items-center justify-center border border-white/30 bg-white/10 px-8 text-sm font-semibold text-white backdrop-blur transition hover:bg-white hover:text-black"
        >
          Check Availability
        </a>
        <a
          href="#services"
          class="inline-flex min-h-12 items-center justify-center text-sm font-semibold text-white/90 underline-offset-8 hover:underline"
        >
          Learn More
        </a>
      </div>
    </div>
  </div>
</section>

<section class="border-b border-white/10 bg-black py-16 md:py-20" aria-labelledby="cin-subheading">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 id="cin-subheading" class="font-[family-name:var(--font-display-cinematic)] text-2xl text-white md:text-3xl">
      The art of astonishment
    </h2>
    <p class="mt-4 text-sm leading-relaxed text-white/65 md:text-base">
      Refined strolling magic: personal, surprising, and crafted for sophisticated rooms. When the lights dim and the conversation flows, I make
      the impossible feel effortless.
    </p>
  </div>
</section>
