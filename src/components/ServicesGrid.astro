---
interface Props {
  theme?: 'velvet' | 'noir' | 'cinematic' | 'default';
}

const { theme = 'default' } = Astro.props;

const cardBorder =
  theme === 'velvet'
    ? 'border-[var(--color-velvet-gold)]/20 hover:border-[var(--color-velvet-gold)]/50'
    : 'border-white/10 hover:border-white/25';

const headingFont =
  theme === 'velvet'
    ? 'font-[family-name:var(--font-display-velvet)] text-[var(--color-velvet-gold)]'
    : theme === 'noir'
      ? 'font-[family-name:var(--font-display-noir)] text-white'
      : theme === 'cinematic'
        ? 'font-[family-name:var(--font-display-cinematic)] text-white'
        : 'font-[family-name:var(--font-display-noir)] text-white';

const services = [
  {
    href: '/weddings/',
    emoji: '💍',
    title: 'Weddings & Receptions',
    body:
      'Make your special day unforgettable with magic that brings guests together. Close-up card tricks to mind-reading moments, interactive experiences guests remember from cocktails through the reception.',
  },
  {
    href: '/corporate-events/',
    emoji: '🪄',
    title: 'Corporate Events',
    body:
      'Elevate your corporate event with magic that sparks conversation and connection. Tailored to your event and brand, from intimate close-up to high-energy routines that leave a lasting impact.',
  },
  {
    href: '/private-parties/',
    emoji: '✨',
    title: 'Private Parties',
    body:
      'Interactive magic for birthdays, anniversaries, and milestone gatherings across Greater Vancouver. The same warm, conversational style that breaks the ice and keeps your crowd talking.',
  },
];
---

<section id="services" class="scroll-mt-24 py-16 md:py-24" aria-labelledby="services-heading">
  <div class="mx-auto max-w-6xl px-4">
    <h2 id="services-heading" class:list={['text-center text-3xl md:text-4xl', headingFont]}>
      Performance types
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-base text-white/70">
      Strolling close-up magic where miracles happen inches from your guests, ideal for mingling, cocktails, and connection across Vancouver and
      Surrey.
    </p>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        services.map((s) => (
          <a
            href={s.href}
            class:list={[
              'group flex flex-col rounded-2xl border bg-black/20 p-6 transition',
              cardBorder,
            ]}
          >
            <span class="text-3xl" aria-hidden="true">
              {s.emoji}
            </span>
            <h3 class="mt-4 text-xl font-semibold text-white">{s.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-white/70">{s.body}</p>
            <span class="mt-4 text-sm font-semibold text-amber-300/90 group-hover:text-amber-200">
              Learn more →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
